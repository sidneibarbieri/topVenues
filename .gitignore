# ── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
*.egg
dist/
build/
.eggs/

# ── Virtual environments ─────────────────────────────────────
.venv/
venv/
env/

# ── Data (generated; not part of source) ────────────────────
# Raw downloads, caches, and binaries — large, regeneratable, not tracked.
data/json/
data/cache/
data/checkpoints/
data/log/
data/archive/
data/dblp/
# arXiv early-signal study: harvested snapshot (~46MB) and computed
# matches are regenerated by scripts/early_signal_study.py.
data/arxiv/
*.db
*.pkl
*.bak.*
# CSV files are NOT globally ignored.
# data/dataset/master_dataset.csv is tracked as a derived human-readable export.
# Keep it aligned with data/dataset/papers.db.gz before publishing a release.
# The DB is materialised automatically from data/dataset/papers.db.gz on first run.
!data/dataset/papers.db.gz
data/dataset/*.sync-id
data/legacy/

# ── Logs and caches ──────────────────────────────────────────
*.log
.cache/
.ruff_cache/
.pytest_cache/
.mypy_cache/
pytest-cache-files-*/

# ── LaTeX generated files ────────────────────────────────────
*.aux
*.bbl
*.blg
*.out
*.fls
*.fdb_latexmk
*.synctex.gz

# ── Secrets and local config ─────────────────────────────────
.env
.env.*
!.env.example
*.toml.local
azure_config*.toml

# ── IDE / OS ─────────────────────────────────────────────────
.idea/
.vscode/
.DS_Store
Thumbs.db

# ── Editor / agent admin files ───────────────────────────────
.claude/
memory/
MEMORY.md

# ── Private / internal-only directories ─────────────────────
# These contain unpublished manuscripts and private planning notes.
llmdir/
project-framework/

# ── Manuscript workspaces (kept local) ───────────────────────
# Manuscript sources, references, and build outputs stay outside the
# public artifact to keep the released tool independent from papers.
papers/

# ── Third-party tooling (cloned, not vendored) ───────────────
.tools/
tmp/

# ── Manual paper-acquisition queue (private writing workflow) ─
orders/

# ── Literature-review support (reference PDFs, private workspace) ─
# Reference material and indices for manuscript writing; kept out of the
# public artifact so the released tool stays venue- and manuscript-agnostic.
literature/
