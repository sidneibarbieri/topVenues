# Optional API credentials.
#
# Reproducing the paper's claims does NOT require any key: `bash reproduce.sh`
# runs entirely offline against the committed snapshot.
#
# Keys are only useful when you refresh the corpus from live sources or re-run
# the cross-source baseline, where they raise rate limits. Copy this file to
# `.env` and fill in your own values; `.env` is git-ignored, so your keys stay
# local.
#
#   cp .env.example .env

# Semantic Scholar. Anonymous access works at a lower rate limit.
# Request a key at https://www.semanticscholar.org/product/api
S2_API_KEY=

# OpenAlex. Anonymous access works; a key gives a faster, less contended pool.
# See https://docs.openalex.org/
OPENALEX_API_KEY=
